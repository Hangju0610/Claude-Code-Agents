{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "spec-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-spec-review-issues.sh"
          }
        ]
      },
      {
        "matcher": "tdd-implementer",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-implementation-complete.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-test-failure.sh"
          }
        ]
      },
      {
        "matcher": "tdd-refactorer",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-implementation-complete.sh"
          }
        ]
      },
      {
        "matcher": "code-reviewer-claude|code-reviewer-codex",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-code-review-fail.sh"
          }
        ]
      },
      {
        "matcher": "tdd-orchestrator",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-pipeline-complete.sh"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-pipeline-error.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-dependency-added.sh"
          }
        ]
      }
    ]
  }
}
